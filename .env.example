# ---- Database ----
DATABASE_URL=postgres://ims:ims@localhost:5432/ims

# ---- Scheduler / throttle (backend) ----
# Minimum GLOBAL gap between two sends (the FIFO throttle). Default: 1 hour.
# Set to 0 to disable throttling (handy for demos and tests).
SEND_INTERVAL_MS=3600000
# How often the scheduler checks the queue.
SCHEDULER_TICK_MS=30000
# Retry policy: attempts before a message is marked FAILED, and the
# exponential backoff base (delay = base * 2^(attempt-1)).
MAX_ATTEMPTS=3
RETRY_BACKOFF_BASE_MS=60000

# ---- Servers ----
BACKEND_PORT=3001
GATEWAY_PORT=3002
# Where the backend dispatches sends.
GATEWAY_URL=http://localhost:3002
# Where the gateway reports status transitions back to the backend.
BACKEND_WEBHOOK_URL=http://localhost:3001/api/webhooks/status

# ---- Gateway sender ----
# simulator   = emits status transitions on timers (runs on any OS)
# applescript = real send via Messages.app (requires macOS + Full Disk Access)
GATEWAY_SENDER=simulator

# Simulator timings (only used when GATEWAY_SENDER=simulator)
SIMULATOR_SENT_MS=1000
SIMULATOR_DELIVERED_MS=3000
SIMULATOR_RECEIVED_MS=6000

# ---- Real iMessage gateway (only used when GATEWAY_SENDER=applescript) ----
# Safety lock: when true, the AppleScript sender only logs and never sends.
IMESSAGE_DRY_RUN=true
# Comma-separated E.164 numbers allowed to receive real messages.
# Live sending refuses to run while this is empty.
IMESSAGE_ALLOWLIST=
# Path to the iMessage database (defaults to the standard location).
CHATDB_PATH=/Users/YOUR_USER/Library/Messages/chat.db
# Delivery watcher: poll interval and how long to watch before giving up.
CHATDB_POLL_MS=3000
CHATDB_WATCH_TIMEOUT_MS=300000
# If true, a message never seen in chat.db by the timeout is marked FAILED.
CHATDB_FAIL_ON_TIMEOUT=false
